{
  "name": "orbisql",
  "version": "0.1.0",
  "description": "OrbiSQL - Cross-platform desktop database management tool",
  "main": "./out/main/index.js",
  "author": "OrbiSQL Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "build": "yarn typecheck && electron-vite build",
    "dist": "yarn build && electron-builder",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:win": "yarn build && electron-builder --win",
    "dist:linux": "yarn build && electron-builder --linux"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "csv-parse": "^7.0.1",
    "csv-stringify": "^6.8.1",
    "mysql2": "^3.23.0",
    "pg": "^8.22.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sql-formatter": "^15.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.orbisql.desktop",
    "productName": "OrbiSQL",
    "executableName": "OrbiSQL",
    "artifactName": "OrbiSQL-${version}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "extendInfo": {
        "CFBundleName": "OrbiSQL",
        "CFBundleDisplayName": "OrbiSQL"
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Development",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "packageManager": "yarn@1.22.22"
}
